{
  "name": "flavor-code",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "flavor": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "技术方案报告.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && node -e \"require('fs').cpSync('src/init/codeisland','dist/codeisland',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:install": "node scripts/smoke-install.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/ripgrep": "^1.18.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "emoji-regex": "^10.6.0",
    "ignore": "^7.0.6",
    "ink": "^7.1.0",
    "lodash-es": "^4.17.23",
    "marked": "^16.4.2",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "semver": "^7.7.4",
    "signal-exit": "4.1.0",
    "supports-hyperlinks": "^4.4.0",
    "typescript": "^7.0.2",
    "usehooks-ts": "^3.1.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
