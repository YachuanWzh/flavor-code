{
  "name": "flavor-code",
  "version": "0.9.0",
  "author": "YachuanWzh",
  "type": "module",
  "main": "dist/desktop/main.js",
  "bin": {
    "flavor": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "技术方案报告.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:icons && npm run build:cli && npm run build:desktop",
    "build:icons": "node scripts/build-icons.mjs",
    "build:cli": "tsup && node -e \"require('fs').cpSync('src/init/codeisland','dist/codeisland',{recursive:true})\"",
    "build:desktop": "npm run build:desktop:main && npm run build:desktop:renderer",
    "build:desktop:main": "tsup --config tsup.desktop.config.ts",
    "build:desktop:renderer": "vite build --config vite.desktop.config.ts",
    "desktop:dev": "npm run build:desktop:main && node scripts/desktop-dev.mjs",
    "desktop:start": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --win --dir",
    "desktop:dist": "npm run build && electron-builder --win nsis",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:install": "node scripts/smoke-install.mjs",
    "prepack": "npm run build"
  },
  "build": {
    "appId": "dev.flavorcode.desktop",
    "productName": "Flavor Code",
    "asar": true,
    "icon": "assets/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Flavor-Code-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/ripgrep": "^1.18.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "emoji-regex": "^10.6.0",
    "ignore": "^7.0.6",
    "ink": "^7.1.0",
    "lodash-es": "^4.17.23",
    "marked": "^16.4.2",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semver": "^7.7.4",
    "signal-exit": "4.1.0",
    "supports-hyperlinks": "^4.4.0",
    "typescript": "^7.0.2",
    "usehooks-ts": "^3.1.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.7.0",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.3",
    "tsup": "^8.5.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.27.7": true,
    "electron@42.7.0": true
  }
}
