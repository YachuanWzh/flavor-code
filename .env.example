# Copy to .env and set only the provider you use. Never commit .env.
ANTHROPIC_BASE_URL=http://127.0.0.1:8092
OPENAI_API_KEY=replace-with-your-openai-key
ANTHROPIC_API_KEY=replace-with-your-anthropic-key

# OAuth PKCE — override when the auth server runs on a remote host.
# Defaults point to localhost:8091 for local development.
# OAUTH_AUTHORIZATION_URL=http://127.0.0.1:8091/authorize
# OAUTH_TOKEN_URL=http://127.0.0.1:8091/token
# OAUTH_CALLBACK_HOST=127.0.0.1
# OAUTH_CLIENT_ID=flavor-code-cli
# OAUTH_SCOPE=models:read models:use
