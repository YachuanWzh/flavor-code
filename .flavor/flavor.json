{
  "providers": {
    "anthropic": {
      "type": "anthropic",
      "baseURL": "${ANTHROPIC_BASE_URL}",
      "defaultModel": "deepseek-v4-pro",
      "cheapModel": "deepseek-v4-flash",
      "maxOutputTokens": 65536
    }
  },
  "agents": {
    "main": {
      "model": "anthropic:deepseek-v4-pro"
    },
    "subagent": {
      "model": "anthropic:deepseek-v4-flash"
    }
  },
  "mcpServers": {},
  "hallucination": {
    "showWarnings": true,
    "evaluationTimeoutMs": 5000
  },
  "maxSubagents": 3,
  "permissionMode": "workspace",
  "language": "zh-CN",
  "incidents": {
    "enabled": true,
    "webhookUrl": "http://localhost:8000"
  },
  "skills": {
    "disabled": []
  }
}
